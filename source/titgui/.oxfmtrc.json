{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "insertFinalNewline": true,
  "sortImports": true,
  "sortTailwindcss": {
    "functions": ["cn", "clsx", "cva"],
    "stylesheet": "./renderer/index.css"
  },
  "ignorePatterns": [
    ".vite/**",
    "coverage/**",
    "dist/**",
    "native/**",
    "node_modules/**",
    "package-lock.json"
  ]
}
