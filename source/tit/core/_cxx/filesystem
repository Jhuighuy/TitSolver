#pragma once
#pragma GCC system_header

#include_next <filesystem>
#ifndef Q_MOC_RUN

#include <format>

#ifdef _LIBCPP_VERSION
_LIBCPP_BEGIN_NAMESPACE_STD
#elifdef __GLIBCXX__
namespace std _GLIBCXX_VISIBILITY(default) {
_GLIBCXX_BEGIN_NAMESPACE_VERSION
#endif // ifdef _LIBCPP_VERSION

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

template<>
struct formatter<filesystem::path> {
  static constexpr auto parse(const format_parse_context& context) {
    return context.begin();
  }
  static constexpr auto format(const filesystem::path& path,
                               format_context& context) {
    return std::format_to(context.out(), "{}", path.string());
  }
};

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

#ifdef _LIBCPP_VERSION
_LIBCPP_END_NAMESPACE_STD
#elifdef __GLIBCXX__
_GLIBCXX_END_NAMESPACE_VERSION
} // namespace std
#endif // ifdef _LIBCPP_VERSION

#endif // Q_MOC_RUN
