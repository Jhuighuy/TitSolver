namespace chrono {

struct _ParseData final {
  string format;
  year_month_day* ymd;
};

// C++20 feature, missing in libc++ 20.1.8.
constexpr auto parse(string format, std::chrono::year_month_day& ymd)
    -> _ParseData {
  return _ParseData{std::move(format), &ymd};
}

template<class Stream>
auto operator>>(Stream& is, const _ParseData& data) -> Stream& {
  std::string line;
  if (!std::getline(is, line)) {
    is.setstate(std::ios_base::failbit);
    return is;
  }

  std::tm tm{};
  const auto end_ptr = strptime(line.c_str(), data.format.c_str(), &tm);
  if (end_ptr == nullptr) {
    is.setstate(std::ios_base::failbit);
    return is;
  }

  *data.ymd = year_month_day{year{tm.tm_year + 1900},
                             month{tm.tm_mon + 1},
                             day{tm.tm_mday}};

  is.seekg(end_ptr - line.c_str());
  return is;
}

} // namespace chrono

