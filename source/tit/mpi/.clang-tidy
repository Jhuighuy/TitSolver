# This module is a deliberate FFI boundary over the MPI C library. The MPI
# predefined handles (`MPI_BYTE`, `MPI_COMM_WORLD`, ...) are macros that
# expand to C-style casts through `void*` inside our translation units, so
# the corresponding checks are relaxed here.
InheritParentConfig: true
Checks: |
  -bugprone-casting-through-void
  -cppcoreguidelines-pro-type-cstyle-cast

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
