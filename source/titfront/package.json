{
  "name": "titfront",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "lint": "eslint . && npx @biomejs/biome check ./src *.js *.ts",
