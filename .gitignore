# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Ignore everything by default, but scan all directories.
*
*~
!*/

# Ignore output directories.
.cache/
/output/

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Git(Hub) files.
!.git*
!/.github/**

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Project and editor configuration files.
!/.vscode/settings.json
!/sonar-project.properties
!/vcpkg.json

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# CMake files.
!/cmake/*.cmake
!/cmake/codespell.txt
!CMakeLists.txt

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# C++ files.
!*.hpp
!*.cpp
!*.cpp.in
!.clang-format
!.clang-tidy

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Web files.
!*.astro
!*.css
!*.html
!*.js
!*.jsx
!*.md
!*.mdx
!*.mjs
!*.mts
!*.ts
!*.tsx
!.oxfmtrc.json
!.oxlintrc.json
!package.json
!tsconfig.json

# Ignore in-tree artifacts.
.astro/
.vite/
dist/
native/
node_modules/

# `dist/` above is a web build artifact directory; the C++ library named
# `dist` is real source.
!source/tit/dist/

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Test files.
!tests/**/*

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Scripts.
!*.sh
!*.sh.in

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Assets.
!*.icns
!*.svg

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
