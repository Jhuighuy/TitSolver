import chevronLeftIcon from "@tabler-outline/chevron-left.svg?raw";
import chevronRightIcon from "@tabler-outline/chevron-right.svg?raw";
import { getRelativeHref, type ManualPage } from "~/pages";

const { currentPath, prev, next } = Astro.props as {
  currentPath: string;
  prev?: ManualPage;
  next?: ManualPage;
};

const hasOnlyPrev = prev !== undefined && next === undefined;
const hasOnlyNext = prev === undefined && next !== undefined;
---

<footer class="page-footer">
  <nav
    class:list={[
      "prev-next",
      hasOnlyPrev && "has-only-prev",
      hasOnlyNext && "has-only-next",
    ]}
    aria-label="Previous and next page links"
  >
    {
      prev ? (
        <a href={getRelativeHref(currentPath, prev.path)}>
          <div class="prev-next-header">
            <span
              class="prev-next-icon"
              aria-hidden="true"
              set:html={chevronLeftIcon}
            />
            <span class="prev-next-label">Previous</span>
          </div>
          <strong>{prev.title}</strong>
        </a>
      ) : (
        <div class="prev-next-spacer" />
      )
    }
    {
      next ? (
        <a class="is-next-link" href={getRelativeHref(currentPath, next.path)}>
          <div class="prev-next-header is-next">
            <span class="prev-next-label">Next</span>
            <span
              class="prev-next-icon"
              aria-hidden="true"
              set:html={chevronRightIcon}
            />
          </div>
          <strong>{next.title}</strong>
        </a>
      ) : (
        <div class="prev-next-spacer" />
      )
    }
  </nav>
</footer>

<style>
  .page-footer {
    margin-top: 1rem;
  }

  .prev-next {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .prev-next a,
  .prev-next-spacer {
    min-height: 5.5rem;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--border-color) 95%, transparent);
    border-radius: var(--radius-medium);
    background: var(--panel-background);
    box-shadow: 0 14px 32px var(--shadow-color);
  }

  .prev-next.has-only-prev > a:first-child {
    grid-column: 1;
  }

  .prev-next.has-only-prev > .prev-next-spacer:last-child {
    grid-column: 2;
    visibility: hidden;
  }

  .prev-next.has-only-next > .prev-next-spacer:first-child {
    grid-column: 1;
    visibility: hidden;
  }

  .prev-next.has-only-next > a:last-child {
    grid-column: 2;
  }

  .prev-next a:hover {
    text-decoration: none;
    border-color: color-mix(
      in srgb,
      var(--accent-strong) 42%,
      var(--border-color)
    );
  }

  .prev-next a {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.25rem;
  }

  .prev-next a.is-next-link {
    text-align: right;
    align-items: flex-end;
  }

  .prev-next-header {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .prev-next-header.is-next {
    justify-content: flex-end;
  }

  .prev-next-label {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .prev-next-icon {
    width: 1rem;
    height: 1rem;
    color: var(--accent-color);
    flex: 0 0 auto;
  }

  .prev-next-icon :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 960px) {
    .prev-next {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-color-scheme: dark) {
    .prev-next a,
    .prev-next-spacer {
      box-shadow: 0 22px 54px rgba(0, 0, 0, 0.5);
    }
  }
</style>
