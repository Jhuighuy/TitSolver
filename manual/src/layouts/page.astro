import type { MarkdownHeading } from "astro";
import { readFileSync } from "node:fs";
import path from "node:path";

import Breadcrumbs from "~/components/breadcrumbs.astro";
import PrevNext from "~/components/prev-next.astro";
import Toc from "~/components/toc.astro";
import {
  getBreadcrumbs,
  getPage,
  getPagePathFromUrl,
  getPrevNext,
} from "~/pages";
import "~/styles/global.css";

const { headings = [] } = Astro.props as {
  headings?: MarkdownHeading[];
};

const currentPath = getPagePathFromUrl(Astro.url);
const page = getPage(currentPath);
const isHomePage = currentPath === "/index.html";
const breadcrumbs = getBreadcrumbs(currentPath);
const sections = headings.filter((heading) => heading.depth === 2);
const prevNext = getPrevNext(currentPath);
const projectMetadata = JSON.parse(
  readFileSync(path.resolve(process.cwd(), "..", "vcpkg.json"), "utf-8"),
) as {
  "version-string"?: string;
};
const manualVersion = projectMetadata["version-string"] ?? "unknown";
const copyrightYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{page.title} | BlueTit Solver</title>
  </head>

  <body>
    <div class="shell">
      <div class:list={["site-frame", isHomePage && "is-home"]}>
        <main class:list={["content-column", isHomePage && "is-home"]}>
          <div class="breadcrumbs-row">
            <Breadcrumbs breadcrumbs={breadcrumbs} currentPath={currentPath} />
          </div>

          <article class="content">
            <Toc sections={sections} />
            <slot />
          </article>

          <PrevNext
            currentPath={currentPath}
            prev={prevNext.prev}
            next={prevNext.next}
          />
        </main>

        <footer class="site-footer">
          <p>BlueTit Solver {manualVersion}</p>
          <p>&copy; {copyrightYear} Oleg Butakov</p>
        </footer>
      </div>
    </div>

    <script is:inline>
      document
        .querySelectorAll('mjx-container[display="true"] svg[data-labels="true"]')
        .forEach((labelSvg) => {
          const labelNode = labelSvg.querySelector('g[id^="mjx-eqn:"]');
          if (labelNode === null) return;

          const equationId = labelNode.id.slice("mjx-eqn:".length);
          if (/^\d+$/.test(equationId)) {
            labelSvg.style.display = "none";
          }
        });
    </script>
  </body>
</html>

<style>
  .shell {
    min-height: 100vh;
  }

  .site-frame {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.2rem 1.5rem 2rem;
  }

  .site-frame.is-home {
    padding-top: 8vh;
  }

  .content-column {
    width: 100%;
    min-width: 0;
  }

  .content-column.is-home .content {
    padding: clamp(2rem, 3vw + 1rem, 3.5rem);
  }

  .content-column.is-home {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 8vh - 4rem);
  }

  .breadcrumbs-row {
    display: flex;
    align-items: flex-start;
    margin: 0 0 0.45rem;
  }

  .content {
    display: flex;
    flex-direction: column;
    padding: clamp(1.15rem, 1.4vw + 0.9rem, 2.25rem);
    border-radius: var(--radius-large);
    background: var(--panel-background);
    border: 1px solid color-mix(in srgb, var(--border-color) 95%, transparent);
    box-shadow: 0 18px 45px var(--shadow-color);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.1rem;
    padding: 0 0.25rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .site-footer p {
    margin: 0;
  }

  .content > * {
    order: 3;
  }

  .content > h1:first-of-type {
    order: 1;
  }

  @media (max-width: 960px) {
    .site-frame.is-home {
      padding-top: 1.5rem;
    }

    .content-column.is-home {
      min-height: auto;
    }

    .breadcrumbs-row {
      margin-bottom: 0.75rem;
    }

    .site-footer {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
